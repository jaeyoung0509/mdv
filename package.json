{
  "name": "@ejaebbang/mdv-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @ejaebbang/mdv-desktop tauri dev",
    "build": "pnpm --filter @ejaebbang/mdv-desktop build && pnpm --filter @ejaebbang/mdv-desktop tauri build",
    "typecheck": "pnpm --filter @ejaebbang/mdv-desktop typecheck",
    "cli": "pnpm --filter @ejaebbang/mdv",
    "link:cli": "cd packages/cli && npm link"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
